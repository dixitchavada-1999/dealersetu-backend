# Environment Configuration Example
# Copy this file to .env and fill in real values. Never commit .env.

# Environment: 'development' locally, 'production' on Railway/Render
NODE_ENV=development

# Server Port (Railway auto-sets PORT in production)
PORT=3000

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/api-shop
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb://127.0.0.1:27017/api-shop

# JWT signing secret (generate with: openssl rand -base64 32)
JWT_SECRET=replace_with_strong_random_string

# Cloudinary credentials (required in production — Railway filesystem is ephemeral)
# Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — comma-separated allowed origins for production
# Example: https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=*

# ── Optional (feature-specific) ─────────────────────────────────

# Refresh-token signing key (fallback: JWT_SECRET + "_refresh")
# JWT_REFRESH_SECRET=

# Master login password (override the default "666666" in production)
# MASTER_PASSWORD=

# SMS via MSG91
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# SMS via Twilio (fallback)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# SMTP for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
